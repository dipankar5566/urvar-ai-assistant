ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram group chat ID for weekly automated reports
# To get your group ID: add the bot to your group, send a message,
# then run: curl https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat":{"id": -XXXXXXXXX} in the group message entry
TELEGRAM_GROUP_ID=your_group_chat_id_here
